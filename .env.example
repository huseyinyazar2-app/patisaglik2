TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=replace-with-server-side-token

# Browser-side direct Turso access is only for temporary local prototypes.
# Do not ship these in a production PWA/Capacitor build.
VITE_TURSO_DATABASE_URL=
VITE_TURSO_AUTH_TOKEN=

# Optional local AI prototype key. Prefer server-side proxy for production.
VITE_GEMINI_API_KEY=

# Production API base for frontend builds. Same-origin if empty.
VITE_API_BASE_URL=

# Server-only API env. Do not prefix secrets with VITE.
PORT=3000
CORS_ORIGIN=*
B2_BUCKET_NAME=patisaglikb2
B2_S3_ENDPOINT=s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
